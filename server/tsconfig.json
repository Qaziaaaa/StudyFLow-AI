{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@studyflow/shared": ["../shared/types.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "tests/**/*", "../shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
